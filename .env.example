# Telegram: @BotFather
BOT_TOKEN=your_telegram_bot_token

# TronFees backend (TELEGRAM_BOT_API.md)
TRONFEES_SERVICE_API_KEY=your_tronfees_service_api_key
# Optional override:
# TRONFEES_API_BASE_URL=https://tron-fees-api.tronpay.me

# Backend → bot webhook (delegation order status)
# Set WEBHOOK_ENABLED=true in production; same secret as TRONFEES_BOT_WEBHOOK_SECRET on backend
WEBHOOK_ENABLED=false
WEBHOOK_PORT=3000
WEBHOOK_SECRET=your_shared_webhook_secret
# WEBHOOK_DEDUP_TTL_MS=86400000
#
# Stage deploy: container tronfees-bot on external network tronfees-net (same as API compose)
# Host webhook: 127.0.0.1:3000 → container:3000
# Bot → API (GitHub secret TRONFEES_API_BASE_URL), e.g. http://tronfees-api:8080
# API → bot webhook: http://tronfees-bot:3000/webhooks/delegation-order
